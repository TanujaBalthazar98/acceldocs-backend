# Database
DATABASE_URL=sqlite:///./acceldocs.db

# Google OAuth
GOOGLE_CLIENT_ID=your-client-id
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_OAUTH_TOKEN_FILE=oauth-token.json

# Google Drive credentials (choose one mode)
# 1) Service account key (if org policy allows key creation)
GOOGLE_SERVICE_ACCOUNT_FILE=service-account.json
# 2) OR OAuth token file above (recommended when key creation is blocked)
GOOGLE_DRIVE_ROOT_FOLDER_ID=your-root-folder-id

# MkDocs site repo (for git-based publishing)
DOCS_REPO_PATH=./docs-site
DOCS_REPO_URL=https://github.com/your-org/acceldocs-site.git

# Server
HOST=0.0.0.0
PORT=8000
SECRET_KEY=change-me-in-production
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Netlify (optional — for triggering deploys)
NETLIFY_SITE_ID=
NETLIFY_AUTH_TOKEN=
