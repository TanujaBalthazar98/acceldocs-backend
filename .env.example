# Database
DATABASE_URL=sqlite:///./acceldocs.db

# Google OAuth
GOOGLE_CLIENT_ID=your-client-id
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_OAUTH_REDIRECT_URI=https://localhost:8081/auth/callback
GOOGLE_OAUTH_TOKEN_FILE=oauth-token.json

# Google Drive credentials (choose one mode)
# 1) Service account key (if org policy allows key creation)
GOOGLE_SERVICE_ACCOUNT_FILE=service-account.json
# 2) OR OAuth token file above (recommended when key creation is blocked)
GOOGLE_DRIVE_ROOT_FOLDER_ID=your-root-folder-id

# MkDocs site repo (for git-based publishing)
DOCS_REPO_PATH=./docs-site
DOCS_REPO_URL=https://github.com/your-org/acceldocs-site.git

# Server
HOST=0.0.0.0
PORT=8000
SECRET_KEY=  # Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
AUTO_CREATE_SCHEMA=false
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# HTML -> Markdown conversion
# auto (default): try Pandoc first, fallback to markdownify
# pandoc: force Pandoc first-pass (still falls back if unavailable)
# markdownify: legacy converter only
HTML_TO_MD_ENGINE=auto
# Optional explicit pandoc binary path if not on PATH
PANDOC_PATH=pandoc
